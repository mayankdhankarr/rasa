# Copy this file to .env and replace placeholders before running the app
# cp .env.example .env

# Gmail SMTP configuration for Contact Brief Form mail delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-google-app-password

SMTP_FROM="RASA Contact <your-gmail-address@gmail.com>"

CONTACT_BRIEF_TO=rasa.helpcare@gmail.com
